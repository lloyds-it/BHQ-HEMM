[Unit]
Description=.NET Web API App running on Linux for BHQ HEMM

[Service]
WorkingDirectory=/var/www/bhq-hemm/backend
ExecStart=/usr/bin/dotnet /var/www/bhq-hemm/backend/EquipmentLogApi.dll --urls "http://127.0.0.1:5100"
Restart=always
# Restart service after 10 seconds if the dotnet service crashes:
RestartSec=10
KillSignal=SIGINT
SyslogIdentifier=bhq-hemm
User=www-data
Environment=ASPNETCORE_ENVIRONMENT=Production

[Install]
WantedBy=multi-user.target
